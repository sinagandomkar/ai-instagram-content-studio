# Copy to .env and fill in. See docs/DEPLOYMENT.md for where each key comes from.

# Prisma CLI only (migrate/generate) — the app itself resolves the SQLite file
# relative to lib/prisma.ts, not from this var. See lib/prisma.ts for why.
DATABASE_URL="file:./dev.db"

# Google AI Studio → https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=

# Composio dashboard → https://dashboard.composio.dev/settings
COMPOSIO_API_KEY=
# Composio → Toolkits → Instagram → create an auth config, copy its id
COMPOSIO_INSTAGRAM_AUTH_CONFIG_ID=
# Fixed Composio userId for V1's single local user — any stable string works
COMPOSIO_USER_ID=local-user

# Docker only — absolute path override for the SQLite file (see lib/prisma.ts
# and docker-compose.yml). Leave unset for local `npm run dev`.
# SQLITE_DB_PATH=/data/dev.db
